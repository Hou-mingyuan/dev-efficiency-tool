{
  "name": "dev-efficiency-tool",
  "version": "0.1.0",
  "private": true,
  "description": "开发效率提升工具 - AI 驱动的软件开发全流程工具",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:skip-check": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "vite build && npx electron-builder --win --config"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@types/dompurify": "^3.0.5",
    "ant-design-vue": "^4.2.6",
    "dayjs": "^1.11.13",
    "dompurify": "^3.4.1",
    "electron-updater": "^6.8.3",
    "html-to-docx": "^1.8.0",
    "mammoth": "^1.8.0",
    "marked": "^15.0.0",
    "omggif": "^1.0.10",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.3",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "happy-dom": "^17.4.4",
    "less": "^4.2.2",
    "typescript": "~5.7.3",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.3.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.1.2",
    "vue-tsc": "^2.2.8"
  },
  "build": {
    "appId": "com.devtool.efficiency",
    "productName": "开发效率提升工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "methodology-core",
        "to": "methodology-core",
        "filter": [
          "**/*"
        ]
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "开发效率提升工具"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://releases.example.com"
      }
    ]
  }
}
